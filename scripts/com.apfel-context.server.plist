<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.apfel-context.server</string>

    <!--
        Default: Ollama (current backend, gemma4:e4b).
        For apfel: change to ["/opt/homebrew/bin/apfel", "--serve"]
    -->
    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/ollama</string>
        <string>serve</string>
    </array>

    <!-- Start immediately on login and restart if it crashes -->
    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <!--
        Keep models in VRAM indefinitely after first use.
        Default is 5 minutes; -1 means never evict until Ollama restarts.
        This prevents cold-start delays on every Claude session after a gap.
    -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>OLLAMA_KEEP_ALIVE</key>
        <string>-1</string>
    </dict>

    <!-- Prevent tight restart loop on repeated crashes -->
    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>/tmp/apfel-context-server.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/apfel-context-server.stderr.log</string>
</dict>
</plist>
